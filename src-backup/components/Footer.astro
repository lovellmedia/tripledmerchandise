---
const currentYear = new Date().getFullYear();
const domain = "tripledmerchandise.com";
---

<footer class="p-12 md:p-24 bg-slate-900 text-white flex flex-col md:flex-row gap-16 md:items-start justify-between">
  <div class="max-w-md">
    <h2 class="text-5xl font-black uppercase italic tracking-tighter mb-6">Triple D<span class="text-primary">.</span></h2>
    <p class="font-bold text-slate-400 mb-8">
      Your comprehensive resource for ecommerce technical vocabulary, trends, and industry insights. Built for merchants, developers, and digital commerce professionals.
    </p>
    <div class="flex gap-4">
      <span class="material-symbols-outlined brutalist-border p-2 border-white cursor-pointer hover:bg-white hover:text-slate-900 transition-all">language</span>
      <span class="material-symbols-outlined brutalist-border p-2 border-white cursor-pointer hover:bg-white hover:text-slate-900 transition-all">mail</span>
      <span class="material-symbols-outlined brutalist-border p-2 border-white cursor-pointer hover:bg-white hover:text-slate-900 transition-all">rss_feed</span>
    </div>
  </div>
  <div class="flex flex-col gap-8 w-full md:w-auto">
    <h3 class="text-xl font-black uppercase underline decoration-primary decoration-4 underline-offset-8">Quick Links</h3>
    <div class="grid grid-cols-2 gap-x-12 gap-y-2 text-xs font-black uppercase">
      <a class="hover:text-primary transition-colors" href="/ecommerce/">Overview</a>
      <a class="hover:text-primary transition-colors" href="/ecommerce/history/">History</a>
      <a class="hover:text-primary transition-colors" href="/ecommerce/technical-deep-dive/">Technical</a>
      <a class="hover:text-primary transition-colors" href="/ecommerce/ontology/">Glossary</a>
      <a class="hover:text-primary transition-colors" href="/ecommerce/trends/">Trends</a>
      <a class="hover:text-primary transition-colors" href="/ecommerce/tools/">Tools</a>
      <a class="hover:text-primary transition-colors" href="/ecommerce/challenges/">Challenges</a>
    </div>
  </div>
</footer>
<div class="w-full bg-primary py-2 px-6 flex justify-between items-center text-[10px] font-black uppercase text-white">
  <span>&copy; {currentYear} {domain}</span>
  <span>Ecommerce Technical Resource Hub</span>
</div>

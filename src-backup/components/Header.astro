---
const siteTitle = "Triple D Merchandise";
const navLinks = [
  { name: "Home", href: "/" },
  { name: "Overview", href: "/ecommerce/" },
  { name: "History", href: "/ecommerce/history/" },
  { name: "Technical", href: "/ecommerce/technical-deep-dive/" },
  { name: "Ontology", href: "/ecommerce/ontology/" },
  { name: "Trends", href: "/ecommerce/trends/" },
  { name: "Tools", href: "/ecommerce/tools/" },
  { name: "Challenges", href: "/ecommerce/challenges/" },
];
---

<header class="w-full bg-background-light dark:bg-background-dark brutalist-border-b sticky top-0 z-50">
  <div class="max-w-[1440px] mx-auto flex items-center justify-between px-6 py-4">
    <div class="flex items-center gap-6">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-3xl font-bold text-primary">shopping_bag</span>
        <a href="/" class="text-2xl font-black tracking-tighter uppercase hover:text-primary transition-colors">
          {siteTitle}
        </a>
      </div>
      
      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-6 border-l-2 border-slate-900 dark:border-slate-100 pl-6">
        {navLinks.map(link => (
          <a 
            href={link.href} 
            class="text-sm font-bold uppercase hover:bg-primary hover:text-white px-2 py-1 transition-colors"
          >
            {link.name}
          </a>
        ))}
      </nav>
    </div>
    
    <!-- Mobile Menu Button -->
    <button 
      id="mobile-menu-toggle"
      class="lg:hidden bg-primary text-white brutalist-border px-4 py-2 font-black shadow-brutal-sm"
      aria-label="Toggle menu"
    >
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>
  
  <!-- Mobile Navigation -->
  <nav id="mobile-menu" class="hidden lg:hidden border-t-2 border-slate-900 dark:border-slate-100 bg-background-light dark:bg-background-dark">
    <div class="flex flex-col p-4 gap-2 font-bold uppercase text-sm">
      {navLinks.map(link => (
        <a 
          href={link.href} 
          class="hover:bg-primary hover:text-white px-4 py-2 transition-colors brutalist-border mb-2"
        >
          {link.name}
        </a>
      ))}
    </div>
  </nav>
</header>

<script is:inline>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
